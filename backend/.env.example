# App
PORT=5000
NODE_ENV=development
NODE_PORT=5000

REACT_PORT=5173

# Migrations
RUN_MIGRATIONS=true

# Database
SCHEMA=app
DB_USERNAME=postgres
DB_PASSWORD=secret_password
DB_NAME=my_database
DB_PORT=5432
DB_CONNECTION=db
DATABASE_URL=postgres://${DB_USERNAME}:${DB_PASSWORD}@db:${DB_PORT}/${DB_NAME}?options=-csearch_path=app,public
DB_MAX_CLIENTS=20
DB_IDLE_TIMEOUT=3000
DB_CONNECTION_TIMEOUT=2000

MOCK_DATE=true
LOG_LEVEL=error

JWT_SECRET=some_secret_hash_string
JWT_EXPIRES_IN=1d

JWT_ACCESS_TOKEN_SECRET=super-secret-access-key-minimum-32-character
JWT_REFRESH_TOKEN_SECRET=super-secret-refresh-key-minimum-32-character
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

