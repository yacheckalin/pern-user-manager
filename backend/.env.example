# App
PORT=5000
NODE_ENV=development

# Migrations
RUN_MIGRATIONS=true

# Database
DB_USERNAME=postgres
DB_PASSWORD=secret_password
DB_NAME=my_database
DB_PORT=5432
DB_CONNECTION=db
DATABASE_URL=postgres://${DB_USERNAME}:${DB_PASSWORD}@db:${DB_PORT}/${DB_NAME}
DB_MAX_CLIENTS=20
DB_IDLE_TIMEOUT=3000
DB_CONNECTION_TIMEOUT=2000

MOCK_DATE=true
LOG_LEVEL=error
